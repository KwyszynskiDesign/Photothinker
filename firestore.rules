rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /photos/{photoId} {
      allow create: if request.resource.data.keys().hasAll(['url', 'storagePath', 'uploadedAt'])
                    && request.resource.data.uploadedAt is int
                    && request.resource.data.url is string;
      // Musi być zsynchronizowane z VITE_ADMIN_EMAIL w .env przy zmianie organizatora.
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'karol2609@gmail.com';
    }
  }
}
